{
  "name": "verdant-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with Verdant parametric crop insurance contracts on Celo",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["celo", "blockchain", "insurance", "crop", "parametric", "minipay", "cusd", "sdk"],
  "author": "Verdant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanmipaul/verdant-sdk"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
